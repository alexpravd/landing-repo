# Database Configuration (PostgreSQL)
# For Neon (recommended for Vercel): https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URI=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Payload CMS Secret (min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-secret-key-at-least-32-characters-long

# Server URL (full URL including protocol)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: CORS Origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
